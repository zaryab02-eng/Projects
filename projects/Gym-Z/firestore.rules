rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // gyms/{gymId} is the root of a gym's private workspace. Each gym stores
    // the owner uid and is readable publicly for rankings while being writable
    // only by the authenticated owner.
    match /gyms/{gymId} {
      // Public read of top-level gym fields powers the unauthenticated
      // Gym Rankings page (name, city, state, activeMemberCount).
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;

      // Every subcollection (members, membershipPlans, blacklist, and each
      // member's renewals) is private to that gym's own authenticated owner.
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/gyms/$(gymId)).data.ownerUid == request.auth.uid;

        match /{nestedCollection}/{nestedId} {
          allow read, write: if request.auth != null && get(/databases/$(database)/documents/gyms/$(gymId)).data.ownerUid == request.auth.uid;
        }
      }
    }
  }
}
