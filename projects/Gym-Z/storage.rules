rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Gym photos live at gyms/{gymId}/photo.jpg. Publicly readable (shown
    // on the Gym Rankings page) but only the gym's own owner can upload.
    match /gyms/{gymId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == gymId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
