# Copy this file to .env and fill in real values.
# All Vite env vars exposed to client code MUST be prefixed with VITE_

# WhatsApp Business number in international format, no "+" or spaces (used for
# "Book a Service", accessory "Buy" buttons and the floating WhatsApp button)
VITE_WHATSAPP_NUMBER=919999999999

# Google Business Profile / review link
VITE_GOOGLE_REVIEWS_URL=https://g.page/r/example-review-link

# Embedded Google Map (Maps Embed API URL or "share > embed" src)
VITE_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=example

# Contact form endpoint (Formspree, Getform, custom API, etc.)
# Leave blank to keep the form in "mailto" fallback mode - see README.
VITE_CONTACT_FORM_ENDPOINT=

# Optional analytics ID (GA4 measurement ID, Plausible domain, etc.)
VITE_ANALYTICS_ID=
